# ==============================================================
# AI Agent Base - 환경 변수 템플릿 파일 (.env.sample)
# ==============================================================
# 사용하시는 LLM 제공자에 맞춰 아래의 값을 채워 넣고,
# 이 파일의 이름을 '.env'로 변경하여 사용하세요.
# (프로젝트 최상단 루트 디렉토리에 .env가 위치해야 연동됩니다.)

# 1. OpenAI (필수 기본 모델 등 가장 대중적인 LLM)
# 발급처: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-본인의 실제 API 키를 입력하세요"

# 2. Anthropic (문장력, 코딩에 특화된 클로드 LLM)
# 발급처: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-본인의 실제 API 키를 입력하세요"

# 3. Google Gemini (방대한 컨텍스트 멀티모달 LLM)
# 발급처: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="AIzaSy...본인의 실제 API 키를 입력하세요"

# 4. Groq (Llama3 등 오픈소스 초고속 추론 API)
# 발급처: https://console.groq.com/keys
GROQ_API_KEY="gsk_본인의 실제 API 키를 입력하세요"
